{
  "ConnectionStrings": {
    "AppDb": "Data Source=supplier-intelligence.db"
  },
  "LocalModel": {
    "Provider": "OpenRouter",
    "BaseUrl": "http://localhost:11434",
    "OpenRouterBaseUrl": "https://openrouter.ai/api/v1",
    "ApiKey": "",
    "Model": "openrouter/free",
    "Temperature": 0.2,
    "TimeoutSeconds": 120,
    "EnableWebSearch": true,
    "SearchMaxResults": 8,
    "SearchMaxTotalResults": 20,
    "SearchExcludedDomains": [
      "wikipedia.org",
      "wikidata.org"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
